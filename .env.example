AI_API_URL=https://your-openai-compatible-endpoint/v1/chat/completions
AI_MODEL=gpt-4.1-mini
AI_API_KEY=your_api_key
AI_TIMEOUT_MS=30000
CRAWLER_NAVIGATION_TIMEOUT_MS=30000
CRAWLER_MANUAL_AUTH_TIMEOUT_MS=120000
CRAWLER_ENABLE_READABLE_MIRROR_FALLBACK=false
CRAWLER_READABLE_MIRROR_BASE_URL=https://r.jina.ai/http://
